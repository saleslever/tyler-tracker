# Postgres connection string.
# Local dev (via docker-compose or system postgres):
DATABASE_URL=postgres://tyler:tyler@localhost:5432/tyler_tracker

# Set to "true" to force SSL (Railway/Neon/Supabase set this automatically
# via URL, but set this if your provider isn't autodetected).
# DATABASE_SSL=true

# Port to listen on (Railway sets this automatically).
PORT=5000
